---
import SectionHead from '../SectionHead.astro';
import Globe from '../Globe.astro';
import { locations } from '../../data/locations';
import { url } from '../../lib/url';

const primaryIndex = locations.findIndex((l) => l.primary);
const markers = locations.map((l) => ({ lat: l.lat, lng: l.lng }));
---

<section class="presence-map" id="sedi">
  <div class="wrap">
    <SectionHead eyebrow="Le nostre sedi">
      <Fragment slot="title">Sette sedi tra Europa e Golfo</Fragment>
      <p slot="lead">
        Presidiamo i centri industriali e finanziari che contano. Gira il
        mappamondo o seleziona una sede: il globo ruota fino al punto esatto
        e si apre la scheda.
      </p>
    </SectionHead>

    <div class="map-layout" data-reveal>
      <div class="globe-panel">
        <Globe id="globe-sedi" markers={markers} primaryIndex={primaryIndex} interactive={true} />
        <button class="map-reset" type="button" data-map-reset hidden>Vista d'insieme</button>
      </div>

      <aside class="map-side">
        <ul class="sede-list" data-sede-list>
          {locations.map((l, i) => (
            <li>
              <button
                type="button"
                class:list={['sede-item', { primary: l.primary }]}
                data-item={String(i)}
                data-lat={String(l.lat)}
                data-lng={String(l.lng)}
                data-role-label={l.role}
              >
                <span class="si-city">{l.city}</span>
                <span class="si-cc">{l.country}</span>
              </button>
            </li>
          ))}
        </ul>

        <div class="sede-card" data-sede-card hidden>
          <span class="sc-eyebrow" data-sc-cc></span>
          <h3 class="sc-city" data-sc-city></h3>
          <p class="sc-role" data-sc-role></p>
          <a href={url('/contatti/')} class="btn btn-solid sc-cta">Contatta questa sede</a>
        </div>
      </aside>
    </div>
  </div>
</section>

<style>
  .presence-map {
    background: var(--panel-2);
    border-top: 1px solid var(--hair-faint);
    border-bottom: 1px solid var(--hair-faint);
  }
  .map-layout {
    display: grid;
    grid-template-columns: 1.35fr 1fr;
    gap: 44px;
    align-items: center;
  }

  .globe-panel {
    position: relative;
    background: transparent;
    padding: 0;
  }

  .map-reset {
    position: absolute; top: 14px; right: 14px;
    font-family: var(--sans); font-size: 12px; font-weight: 700;
    letter-spacing: 0.08em; text-transform: uppercase;
    color: #ECE5D6;
    background: rgba(10, 19, 34, 0.8);
    border: 1px solid var(--hair);
    border-radius: 20px;
    padding: 8px 16px; cursor: pointer;
    backdrop-filter: blur(6px);
    transition: all 0.25s ease;
  }
  .map-reset[hidden] { display: none; }
  .map-reset:hover { border-color: var(--gold); color: var(--gold-soft); }

  /* elenco */
  .sede-list { list-style: none; border-top: 1px solid var(--hair-faint); }
  .sede-item {
    width: 100%; text-align: left;
    display: flex; flex-direction: column; gap: 4px;
    padding: 15px 14px;
    background: transparent; border: none;
    border-bottom: 1px solid var(--hair-faint);
    cursor: pointer;
    transition: background 0.25s ease, padding 0.25s ease;
  }
  .sede-item:hover, .sede-item.active { background: var(--panel); padding-left: 20px; }
  .si-city { font-family: var(--disp); font-size: 20px; font-weight: 700; color: var(--ink); }
  .sede-item.primary .si-city::after {
    content: "◆"; font-size: 9px; color: var(--accent-text);
    vertical-align: super; margin-left: 8px;
  }
  .si-cc {
    font-family: var(--sans); font-size: 11px; font-weight: 600; letter-spacing: 0.18em;
    text-transform: uppercase; color: var(--accent-text);
  }

  /* scheda */
  .sede-card {
    margin-top: 24px;
    padding: 24px 28px;
    background: var(--panel);
    border: 1px solid var(--hair);
    border-left: 3px solid var(--accent);
    border-radius: var(--radius-card);
    animation: cardIn 0.4s ease both;
  }
  .sede-card[hidden] { display: none; }
  @keyframes cardIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: none; } }
  .sc-eyebrow {
    font-family: var(--sans); font-size: 11px; font-weight: 700; letter-spacing: 0.2em;
    text-transform: uppercase; color: var(--accent-text);
  }
  .sc-city { font-family: var(--disp); font-size: 30px; font-weight: 800; color: var(--ink); margin: 8px 0 8px; }
  .sc-role { color: var(--muted); font-size: 17px; line-height: 1.5; }
  .sc-cta { margin-top: 20px; font-size: 12px; padding: 12px 22px; }

  @media (max-width: 900px) {
    .map-layout { grid-template-columns: 1fr; gap: 30px; }
  }
</style>

<script>
  const canvas = document.querySelector<HTMLCanvasElement & { __globe?: { focus: (a: number, b: number, c: number) => void; reset: () => void } }>('#globe-sedi');
  const items = [...document.querySelectorAll<HTMLButtonElement>('[data-item]')];
  const card = document.querySelector<HTMLElement>('[data-sede-card]');
  const reset = document.querySelector<HTMLButtonElement>('[data-map-reset]');

  const select = (idx: number) => {
    const item = items[idx];
    if (!item) return;
    canvas?.__globe?.focus(+item.dataset.lat!, +item.dataset.lng!, idx);
    items.forEach((it, i) => it.classList.toggle('active', i === idx));
    if (card) {
      (card.querySelector('[data-sc-city]') as HTMLElement).textContent =
        item.querySelector('.si-city')?.textContent ?? '';
      (card.querySelector('[data-sc-cc]') as HTMLElement).textContent =
        item.querySelector('.si-cc')?.textContent ?? '';
      (card.querySelector('[data-sc-role]') as HTMLElement).textContent =
        item.dataset.roleLabel ?? '';
      card.hidden = false;
    }
    if (reset) reset.hidden = false;
  };

  items.forEach((it, i) => it.addEventListener('click', () => select(i)));
  reset?.addEventListener('click', () => {
    canvas?.__globe?.reset();
    items.forEach((it) => it.classList.remove('active'));
    if (card) card.hidden = true;
    if (reset) reset.hidden = true;
  });
</script>
