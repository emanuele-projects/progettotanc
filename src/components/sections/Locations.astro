---
/**
 * Sezione sedi: scena "dall'orbita" (Globe, vettoriale e animata) su
 * banda navy notte in cui la scena si dissolve, + le sette sedi
 * raccontate per tipologia (direzionali / legale / rappresentanza).
 * Usata in home (compact, con rimando a Team & Sedi) e nella pagina
 * Team & Sedi.
 */
import SectionHead from '../SectionHead.astro';
import Globe from '../Globe.astro';
import { locations, locationGroups, typeLabels } from '../../data/locations';
import { url } from '../../lib/url';

interface Props {
  compact?: boolean;
}
const { compact = false } = Astro.props;

const markers = locations.map((l) => ({
  lat: l.lat,
  lng: l.lng,
  city: l.city,
  country: l.country,
  typeLabel: typeLabels[l.type],
  note: l.note,
  primary: l.primary,
}));
---

<section class="presence on-navy" id="sedi">
  <div class="wrap">
    <SectionHead eyebrow="Le nostre sedi">
      <Fragment slot="title">Sette sedi tra Europa e Golfo</Fragment>
      <p slot="lead">
        Presidiamo i centri industriali e finanziari che contano: una rete di
        sedi con ruoli distinti, sotto un'unica regìa. Trascina il globo e
        tocca un segnaposto.
      </p>
    </SectionHead>
  </div>

  <div class="scene-band" data-reveal>
    <Globe markers={markers} />
  </div>

  <div class="wrap">
    {!compact && (
    <div class="groups" data-reveal>
      {locationGroups.map((g) => (
        <article class="group">
          <span class="g-tag">{g.tag}</span>
          <h3 class="g-title">{g.title}</h3>
          <p class="g-desc">{g.description}</p>
          <ul class="g-cities">
            {g.cities.map((c) => (
              <li class:list={['g-city', { primary: c.primary }]}>
                <span class="gc-name">{c.city}</span>
                <span class="gc-cc">{c.country}</span>
              </li>
            ))}
          </ul>
        </article>
      ))}
    </div>
    )}

    {compact && (
      <div class="presence-more">
        <a href={url('/team/')} class="btn">Team &amp; sedi</a>
      </div>
    )}
  </div>
</section>

<style>
  /* banda navy notte: la scena orbitale si dissolve in questo sfondo */
  .presence {
    background: #050B16;
    border-top: 1px solid rgba(194, 163, 91, 0.18);
    border-bottom: 1px solid rgba(194, 163, 91, 0.18);
    padding-bottom: 70px;
  }
  .presence :global(.sec-head h2) { color: #FFFFFF; }
  .presence :global(.sec-head .eyebrow) { color: #D8BE84; }
  .presence :global(.sec-head .eyebrow::before) { border-color: #C2A35B; }
  .presence :global(.sec-head p) { color: rgba(236, 229, 214, 0.62); }

  .scene-band {
    max-width: 1400px;
    margin: 0 auto;
  }

  /* gruppi di sedi, su scuro */
  .groups {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 40px;
    margin-top: 46px;
  }
  .group { border-top: 1px solid rgba(236, 229, 214, 0.14); padding-top: 20px; }

  .g-tag {
    display: inline-block;
    font-family: var(--sans); font-size: 10.5px; font-weight: 700;
    letter-spacing: 0.22em; text-transform: uppercase;
    color: #D8BE84;
  }
  .g-tag::before {
    content: "◆";
    font-size: 8px;
    color: #C2A35B;
    margin-right: 9px;
    vertical-align: middle;
  }
  .g-title {
    font-family: var(--disp); font-size: 23px; font-weight: 700;
    color: #FFFFFF; margin-top: 8px;
  }
  .g-desc {
    color: rgba(236, 229, 214, 0.6); font-size: 15px; line-height: 1.6;
    margin-top: 8px;
  }
  .g-cities {
    list-style: none;
    display: flex; flex-wrap: wrap; gap: 10px;
    margin-top: 16px;
  }
  .g-city {
    display: flex; flex-direction: column; gap: 2px;
    padding: 9px 16px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(236, 229, 214, 0.14);
    border-radius: var(--radius-card);
  }
  .g-city.primary { border-color: rgba(194, 163, 91, 0.5); }
  .gc-name { font-family: var(--disp); font-size: 17px; font-weight: 700; color: #F2EDE1; }
  .g-city.primary .gc-name::after {
    content: "◆"; font-size: 8px; color: #C2A35B;
    vertical-align: super; margin-left: 6px;
  }
  .gc-cc {
    font-family: var(--sans); font-size: 10px; font-weight: 600;
    letter-spacing: 0.14em; text-transform: uppercase; color: rgba(216, 190, 132, 0.7);
  }

  .presence-more { text-align: center; margin-top: 44px; }

  @media (max-width: 960px) {
    .groups { grid-template-columns: 1fr; gap: 26px; }
  }
</style>
