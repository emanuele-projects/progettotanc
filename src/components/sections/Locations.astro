---
/**
 * Sezione sedi della homepage: mappamondo autorotante (drag per
 * esplorare) + griglia delle città. L'esperienza completa con
 * selezione e schede vive in /sedi (LocationsMap).
 */
import SectionHead from '../SectionHead.astro';
import Globe from '../Globe.astro';
import { locations } from '../../data/locations';
import { url } from '../../lib/url';

const primaryIndex = locations.findIndex((l) => l.primary);
const markers = locations.map((l) => ({ lat: l.lat, lng: l.lng }));
---

<section class="presence" id="sedi">
  <div class="wrap">
    <SectionHead eyebrow="Le nostre sedi">
      <Fragment slot="title">Sette sedi tra Europa e Golfo</Fragment>
      <p slot="lead">
        Presidiamo i centri industriali e finanziari che contano: accesso
        diretto a mercati, capitali e opportunità, con una sola regìa.
      </p>
    </SectionHead>

    <div class="compact-layout" data-reveal>
      <a href={url('/sedi/')} class="globe-panel" aria-label="Vai alla pagina delle sedi">
        <Globe id="globe-home" markers={markers} primaryIndex={primaryIndex} interactive={false} />
      </a>

      <div class="loc-col">
        <div class="loc-row">
          {locations.map((l) => (
            <a href={url('/sedi/')} class:list={['loc', { primary: l.primary }]}>
              <span class="city">{l.city}</span>
              <span class="cc">{l.country}</span>
              <span class="role">{l.role}</span>
            </a>
          ))}
        </div>
        <div class="loc-more">
          <a href={url('/sedi/')} class="btn">Tutte le sedi e i riferimenti</a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .presence {
    background: var(--panel-2);
    border-top: 1px solid var(--hair-faint);
    border-bottom: 1px solid var(--hair-faint);
  }
  .compact-layout {
    display: grid;
    grid-template-columns: 0.9fr 1.25fr;
    gap: 44px;
    align-items: center;
  }
  .globe-panel {
    display: block;
    background: transparent;
    padding: 0;
  }

  .loc-row {
    display: flex; flex-wrap: wrap;
    border-top: 1px solid var(--hair-faint);
  }
  .loc {
    flex: 1 1 33%;
    min-width: 170px;
    padding: 22px 20px;
    border-right: 1px solid var(--hair-faint);
    border-bottom: 1px solid var(--hair-faint);
    display: block;
    transition: background 0.3s ease;
  }
  .loc:hover { background: var(--panel); }
  .loc.primary .city::after {
    content: "◆";
    font-size: 9px;
    color: var(--accent-text);
    vertical-align: super;
    margin-left: 7px;
  }
  .city { display: block; font-family: var(--disp); font-size: 22px; font-weight: 700; color: var(--ink); }
  .cc {
    display: block;
    font-family: var(--sans); font-size: 10px; font-weight: 600; letter-spacing: 0.2em;
    color: var(--accent-text); text-transform: uppercase; margin-top: 6px;
  }
  .role { display: block; color: var(--muted); font-size: 14px; margin-top: 8px; }

  .loc-more { text-align: center; margin-top: 36px; }

  @media (max-width: 900px) {
    .compact-layout { grid-template-columns: 1fr; gap: 30px; }
    .globe-panel { max-width: 420px; margin: 0 auto; }
    .loc { flex: 1 1 50%; }
  }
</style>
