---
/**
 * Sezione sedi: porzione di globo in prospettiva (illustrativa) +
 * le sette sedi raccontate per tipologia (direzionali / legale /
 * rappresentanza), con descrizione generica per gruppo. Usata sia in
 * home (compact, con rimando alla pagina) sia nella pagina Team & Sedi.
 */
import SectionHead from '../SectionHead.astro';
import Globe from '../Globe.astro';
import { locations, locationGroups, typeLabels } from '../../data/locations';
import { url } from '../../lib/url';

interface Props {
  compact?: boolean;
}
const { compact = false } = Astro.props;

const markers = locations.map((l) => ({
  lat: l.lat,
  lng: l.lng,
  city: l.city,
  typeLabel: typeLabels[l.type],
  primary: l.primary,
}));
---

<section class="presence" id="sedi">
  <div class="wrap">
    <SectionHead eyebrow="Le nostre sedi">
      <Fragment slot="title">Sette sedi tra Europa e Golfo</Fragment>
      <p slot="lead">
        Presidiamo i centri industriali e finanziari che contano: una rete di
        sedi con ruoli distinti, sotto un'unica regìa.
      </p>
    </SectionHead>

    <div class="presence-layout" data-reveal>
      <div class="globe-frame">
        <Globe markers={markers} label="Porzione di globo con le sedi tra Europa e Golfo" />
      </div>

      <div class="groups">
        {locationGroups.map((g) => (
          <article class="group">
            <span class="g-tag">{g.tag}</span>
            <h3 class="g-title">{g.title}</h3>
            <p class="g-desc">{g.description}</p>
            <ul class="g-cities">
              {g.cities.map((c) => (
                <li class:list={['g-city', { primary: c.primary }]}>
                  <span class="gc-name">{c.city}</span>
                  <span class="gc-cc">{c.country}</span>
                </li>
              ))}
            </ul>
          </article>
        ))}
      </div>
    </div>

    {compact && (
      <div class="presence-more">
        <a href={url('/team/')} class="btn">Team &amp; sedi</a>
      </div>
    )}
  </div>
</section>

<style>
  .presence {
    background: var(--panel-2);
    border-top: 1px solid var(--hair-faint);
    border-bottom: 1px solid var(--hair-faint);
  }
  .presence-layout {
    display: grid;
    grid-template-columns: 0.95fr 1.1fr;
    gap: 52px;
    align-items: center;
  }

  /* porzione di globo: nessun riquadro, sfuma nello sfondo */
  .globe-frame {
    position: relative;
    aspect-ratio: 560 / 520;
    background: transparent;
    overflow: visible;
  }

  /* gruppi di sedi */
  .groups { display: flex; flex-direction: column; }
  .group {
    padding: 22px 0;
    border-top: 1px solid var(--hair-faint);
  }
  .group:first-child { border-top: none; padding-top: 0; }
  .group:last-child { padding-bottom: 0; }

  .g-tag {
    display: inline-block;
    font-family: var(--sans); font-size: 10.5px; font-weight: 700;
    letter-spacing: 0.22em; text-transform: uppercase;
    color: var(--accent-text);
  }
  .g-tag::before {
    content: "◆";
    font-size: 8px;
    color: var(--gold);
    margin-right: 9px;
    vertical-align: middle;
  }
  .g-title {
    font-family: var(--disp); font-size: 24px; font-weight: 700;
    color: var(--ink); margin-top: 8px;
  }
  .g-desc {
    color: var(--muted); font-size: 15.5px; line-height: 1.6;
    margin-top: 8px; max-width: 46ch;
  }
  .g-cities {
    list-style: none;
    display: flex; flex-wrap: wrap; gap: 10px;
    margin-top: 16px;
  }
  .g-city {
    display: flex; flex-direction: column; gap: 2px;
    padding: 9px 16px;
    background: var(--panel);
    border: 1px solid var(--hair-faint);
    border-radius: var(--radius-card);
  }
  .g-city.primary { border-color: var(--hair); }
  .gc-name {
    font-family: var(--disp); font-size: 17px; font-weight: 700; color: var(--ink);
  }
  .g-city.primary .gc-name::after {
    content: "◆"; font-size: 8px; color: var(--accent-text);
    vertical-align: super; margin-left: 6px;
  }
  .gc-cc {
    font-family: var(--sans); font-size: 10px; font-weight: 600;
    letter-spacing: 0.14em; text-transform: uppercase; color: var(--muted-2);
  }

  .presence-more { text-align: center; margin-top: 44px; }

  @media (max-width: 900px) {
    .presence-layout { grid-template-columns: 1fr; gap: 34px; }
    .globe-frame { max-width: 460px; margin: 0 auto; width: 100%; }
  }
</style>
