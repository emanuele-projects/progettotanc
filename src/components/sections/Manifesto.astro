---
interface Props {
  eyebrow: string;
  sign?: string;
  id?: string;
  ctaLabel?: string;
  ctaHref?: string;
}
const { eyebrow, sign, id = 'chi-siamo', ctaLabel, ctaHref } = Astro.props;
---

<section class="manifesto" id={id}>
  <div class="wrap em-gold">
    <span class="eyebrow" data-reveal>{eyebrow}</span>
    <p class="big" data-reveal><slot /></p>
    {sign && <div class="sign" data-reveal>{sign}</div>}
    {ctaLabel && ctaHref && (
      <div class="manifesto-cta" data-reveal>
        <a href={ctaHref} class="btn">{ctaLabel}</a>
      </div>
    )}
  </div>
</section>

<style>
  .manifesto {
    background: var(--bg-2);
    border-top: 1px solid var(--hair-faint);
    border-bottom: 1px solid var(--hair-faint);
  }
  .big {
    font-family: var(--disp);
    font-size: clamp(26px, 3.4vw, 42px);
    font-weight: 400;
    line-height: 1.3;
    color: var(--ink);
    max-width: 980px;
    margin-top: 28px;
  }
  .sign {
    font-family: var(--sans); font-size: 13px; letter-spacing: 0.2em;
    text-transform: uppercase; color: var(--muted);
    margin-top: 48px;
    display: flex; align-items: center; gap: 16px;
  }
  .sign::before { content: ""; width: 42px; height: 1px; background: var(--accent); }
  .manifesto-cta { margin-top: 36px; }
</style>
