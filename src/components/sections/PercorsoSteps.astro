---
import SectionHead from '../SectionHead.astro';

export interface Step {
  n: string;
  title: string;
  text: string;
}
interface Props {
  eyebrow: string;
  lead: string;
  steps: Step[];
}
const { eyebrow, lead, steps } = Astro.props;
---

<section id="percorso">
  <div class="wrap">
    <SectionHead eyebrow={eyebrow}>
      <Fragment slot="title"><slot name="title" /></Fragment>
      <p slot="lead">{lead}</p>
    </SectionHead>
    <ol class="steps">
      {steps.map((s) => (
        <li class="step" data-reveal>
          <span class="sn">{s.n}</span>
          <div class="step-body">
            <h3>{s.title}</h3>
            <p>{s.text}</p>
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .steps {
    list-style: none;
    max-width: 820px;
    border-top: 1px solid var(--hair);
  }
  .step {
    display: flex; gap: 40px; align-items: baseline;
    padding: 40px 6px 44px;
    border-bottom: 1px solid var(--hair-faint);
  }
  .sn {
    font-family: var(--disp); font-size: 48px;
    font-weight: 800; color: var(--accent-text);
    flex: 0 0 64px;
  }
  .step-body h3 { font-size: 28px; margin-bottom: 10px; }
  .step-body p { color: var(--muted); font-size: 18px; line-height: 1.6; max-width: 560px; }

  @media (max-width: 900px) {
    .step { gap: 22px; flex-direction: column; padding: 32px 0 36px; }
    .sn { flex: none; }
  }
</style>
