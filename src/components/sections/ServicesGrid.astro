---
import SectionHead from '../SectionHead.astro';
import BrandArt from '../BrandArt.astro';
import Carousel from '../Carousel.astro';
import { services } from '../../data/services';
---

<section id="servizi">
  <div class="wrap">
    <SectionHead eyebrow="Aree di intervento">
      <Fragment slot="title">I nostri servizi</Fragment>
      <p slot="lead">
        Sei aree, un'unica regìa: partiamo da una diagnosi onesta e arriviamo a
        risultati che si misurano. Obiettivi chiari, responsabilità definite.
      </p>
    </SectionHead>
    <div data-reveal>
      <Carousel id="servizi-slider" label="I nostri servizi">
        {services.map((s) => (
          <a href={`/servizi/${s.slug}/`} class="svc car-slide">
            <div class="svc-media">
              <BrandArt variant={s.art} ratio="16 / 10" label={s.plainTitle} />
            </div>
            <div class="svc-body">
              <span class="num">{s.num}</span>
              <h3 set:html={s.title} />
              <p>{s.excerpt}</p>
              <span class="arrow">Approfondisci →</span>
            </div>
          </a>
        ))}
      </Carousel>
    </div>
    <div class="svc-all" data-reveal>
      <a href="/servizi/" class="btn">Tutti i servizi</a>
    </div>
  </div>
</section>

<style>
  /* Card practice-areas alla CookGroup, in card-slider con frecce */
  .svc {
    display: block;
    background: var(--panel);
    border: 1px solid var(--hair-faint);
    border-radius: var(--radius-card);
    overflow: hidden;
    transition: border-color 0.35s ease, transform 0.35s ease, box-shadow 0.35s ease;
  }
  .svc:hover {
    border-color: var(--hair);
    transform: translateY(-5px);
    box-shadow: 0 18px 40px rgba(6, 27, 61, 0.08);
  }
  .svc-body { padding: 26px 26px 30px; }
  .num {
    font-family: var(--sans); font-size: 12px; font-weight: 700;
    letter-spacing: 0.18em; color: var(--accent-text);
  }
  .svc h3 { font-size: 23px; margin: 12px 0 10px; line-height: 1.2; transition: color 0.3s; }
  .svc:hover h3 { color: var(--accent-text); }
  .svc p { color: var(--muted); font-size: 16.5px; line-height: 1.6; }
  .arrow {
    display: inline-block;
    margin-top: 18px;
    font-family: var(--sans); font-size: 13px; font-weight: 700;
    letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--accent-text);
    opacity: 0; transform: translateX(-6px);
    transition: all 0.35s ease;
  }
  .svc:hover .arrow { opacity: 1; transform: translateX(0); }
  .svc-all { text-align: center; margin-top: 44px; }
</style>
