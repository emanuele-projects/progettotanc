---
import Carousel from '../Carousel.astro';
import { badges } from '../../data/why-us';
---

<section class="badges-sec" id="riconoscimenti">
  <div class="wrap">
    <div class="badges-head em-gold" data-reveal>
      <span class="eyebrow">Certificazioni &amp; riconoscimenti</span>
    </div>
    <div data-reveal>
      <Carousel
        id="badges-slider"
        label="Certificazioni e riconoscimenti"
        dots={true}
        slideW="200px"
        slideWTablet="200px"
        slideWMobile="180px"
      >
        {badges.map((b) => (
          <div class="badge car-slide">
            <span class="b-label">{b.label}</span>
            <span class="b-note">{b.note}</span>
          </div>
        ))}
      </Carousel>
    </div>
  </div>
</section>

<style>
  .badges-sec {
    padding: 70px 0;
    background: var(--bg-2);
    border-top: 1px solid var(--hair-faint);
    border-bottom: 1px solid var(--hair-faint);
  }
  .badges-head { text-align: center; margin-bottom: 40px; }
  .badges-head .eyebrow { justify-content: center; }
  .badge {
    display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 8px;
    padding: 30px 24px;
    border: 1px solid var(--hair-faint);
    background: var(--panel);
    border-radius: var(--radius-card);
    text-align: center;
    transition: border-color 0.3s ease, box-shadow 0.3s ease;
    min-height: 120px;
  }
  .badge:hover { border-color: var(--hair); box-shadow: 0 12px 28px rgba(6, 27, 61, 0.07); }
  .b-label { font-family: var(--disp); font-size: 21px; font-weight: 700; color: var(--ink); }
  .b-note {
    font-family: var(--sans); font-size: 10px; font-weight: 600; letter-spacing: 0.2em;
    text-transform: uppercase; color: var(--muted);
  }
</style>
