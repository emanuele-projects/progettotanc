---
/**
 * Menzione della Mentoria in homepage: banda navy con l'ORO di brand
 * e la scena illustrata dedicata — l'unica sezione dorata del sito
 * consulting, ponte verso l'area /mentoria (blu notte + oro).
 */
import BrandArt from '../BrandArt.astro';
import { url } from '../../lib/url';
---

<section class="mentoria-band on-navy" id="mentoria">
  <div class="wrap band-inner">
    <div class="band-text">
      <span class="eyebrow gold" data-reveal>Mentoria — un'area a sé</span>
      <h2 data-reveal>La crescita strategica<br />di chi <em>guida</em></h2>
      <p data-reveal>
        Accanto alla consulenza vive un servizio distinto: l'affiancamento
        personale di fondatori, successori e prime linee verso la crescita
        strategica. Un percorso riservato, con una promessa precisa — rendere
        autonoma la guida aziendale.
      </p>
      <div class="band-cta" data-reveal>
        <a href={url('/mentoria/')} class="btn gold-btn">Scopri la Mentoria</a>
      </div>
    </div>
    <div class="band-art" data-reveal>
      <BrandArt variant="mentoria" ratio="4 / 3" label="Mentoria e crescita della leadership" />
    </div>
  </div>
</section>

<style>
  .mentoria-band {
    background: linear-gradient(160deg, var(--navy) 0%, var(--navy-2) 100%);
    color: var(--on-navy-dim);
    padding: 96px 0;
    overflow: hidden;
  }
  .band-inner {
    display: grid;
    grid-template-columns: 1.15fr 0.85fr;
    gap: 60px;
    align-items: center;
  }
  .band-text { max-width: 640px; }

  /* Firma oro, qualunque sia il tema della pagina ospite */
  .eyebrow.gold { color: var(--gold-soft); }
  .eyebrow.gold::before { background: var(--gold); }
  .mentoria-band h2 {
    font-size: clamp(30px, 3.8vw, 46px);
    color: var(--on-navy);
    margin-top: 18px;
  }
  .mentoria-band h2 em { font-style: normal; color: var(--gold-soft); }
  .mentoria-band p {
    font-size: 20px; font-weight: 300; line-height: 1.65;
    margin-top: 20px;
  }
  .band-cta { margin-top: 34px; }
  .gold-btn {
    background: var(--gold);
    border-color: var(--gold);
    color: #081527;
  }
  .gold-btn:hover {
    background: var(--gold-soft);
    border-color: var(--gold-soft);
    color: #081527;
  }
  .band-art :global(.brand-art) {
    border: 1px solid var(--hair-on-navy);
    border-radius: var(--radius-card);
  }

  @media (max-width: 900px) {
    .band-inner { grid-template-columns: 1fr; gap: 40px; }
  }
</style>
