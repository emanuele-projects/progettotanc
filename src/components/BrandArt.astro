  variant:
    | 'skyline'
    | 'boardroom'
    | 'deal'
    | 'growth'
    | 'succession'
    | 'vault'
    | 'global'
    | 'quality'
    | 'portrait'
    | 'mentoria'
    | 'editorial';
  ratio?: string;
  label?: string;
  class?: string;
}
