const svgBody = scenes[variant] ?? scenes.skyline;
const role = label ? 'img' : 'presentation';
---

<div class:list={['brand-art', className]} style={`aspect-ratio: ${ratio};`}>
  <svg
    viewBox="0 0 800 600"
    preserveAspectRatio="xMidYMid slice"
    role={role}
    aria-label={label || undefined}
    aria-hidden={label ? undefined : 'true'}
  >
    <defs>
      <linearGradient id="ba-sky" x1="0" y1="0" x2="0.6" y2="1">
        <stop offset="0" stop-color="#0B2A5C" />
        <stop offset="0.55" stop-color="#173B78" />
        <stop offset="1" stop-color="#2F55B8" />
      </linearGradient>
      <linearGradient id="ba-navy" x1="0" y1="0" x2="0.5" y2="1">
        <stop offset="0" stop-color="#061B3D" />
        <stop offset="1" stop-color="#0B2A5C" />
      </linearGradient>
    </defs>
    <Fragment set:html={svgBody} />
  </svg>
</div>

<style>
  .brand-art {
    width: 100%;
    overflow: hidden;
    background: #0B2A5C;
  }
  .brand-art svg {
    width: 100%;
    height: 100%;
    display: block;
  }
</style>
