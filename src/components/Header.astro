---
import { site, nav, ctaLabel, ctaHref } from '../data/site';
import { services } from '../data/services';
import { url } from '../lib/url';

const links = nav.filter((item) => !item.highlight);
const mentoria = nav.find((item) => item.highlight);
---

<header data-header>
  <div class="wrap navbar">
    <a href={url('/')} class="brand">
      <span class="name">{site.brand}</span>
      <span class="sub">{site.brandSub}</span>
    </a>
    <nav class="navlinks" id="navlinks" aria-label="Navigazione principale">
      {links.map((item) =>
        item.label === 'Servizi' ? (
          <div class="nav-drop">
            <a href={url(item.href)} aria-haspopup="true">
              {item.label}
              <svg class="caret" viewBox="0 0 10 6" width="10" height="6" aria-hidden="true"><path d="M1 1l4 4 4-4" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>
            </a>
            <div class="drop-menu">
              {services.map((s) => (
                <a href={url(`/servizi/${s.slug}/`)} class="drop-item">
                  <span class="drop-num">{s.num}</span>
                  <span set:html={s.title} />
                </a>
              ))}
            </div>
          </div>
        ) : (
          <a href={url(item.href)}>{item.label}</a>
        )
      )}
      {mentoria && <a href={url(mentoria.href)} class="btn btn-gold nav-mentoria">{mentoria.label}</a>}
      <a href={url(ctaHref)} class="btn btn-solid nav-cta">{ctaLabel}</a>
    </nav>
    <div class="head-actions">
      {mentoria && <a href={url(mentoria.href)} class="btn btn-gold">{mentoria.label}</a>}
      <a href={url(ctaHref)} class="btn btn-solid desk-cta">{ctaLabel}</a>
    </div>
    <button
      class="menu-tog"
      id="menu-tog"
      aria-expanded="false"
      aria-controls="navlinks"
      aria-label="Apri il menu"
    >Menu</button>
  </div>
</header>

<style>
  /* Header CookGroup-like: trasparente sull'hero navy (testo bianco),
     bianco solido al primo scroll. Mentoria = pill oro in evidenza. */
  header {
    position: fixed; top: 0; left: 0; right: 0; z-index: 50;
    padding: 20px 0;
    transition: all 0.4s ease;
    border-bottom: 1px solid transparent;
    color: var(--on-navy);
  }
  header.scrolled {
    padding: 12px 0;
    background: var(--header-bg);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--hair-faint);
    color: var(--ink);
  }
  .navbar { display: flex; align-items: center; justify-content: space-between; gap: 20px; }

  .brand { display: flex; flex-direction: column; line-height: 1; }
  .brand .name { font-family: var(--disp); font-size: 21px; font-weight: 800; letter-spacing: 0.03em; }
  .brand .sub {
    font-family: var(--sans); font-size: 9.5px; font-weight: 600; letter-spacing: 0.3em;
    text-transform: uppercase; margin-top: 5px; opacity: 0.75;
  }

  .navlinks {
    display: flex; gap: 26px; align-items: center;
    font-family: var(--sans); font-size: 14px; font-weight: 600;
    letter-spacing: 0.04em;
  }
  .navlinks a { position: relative; transition: color 0.3s; opacity: 0.92; }
  .navlinks > a:not(.btn)::after,
  .nav-drop > a::after {
    content: ""; position: absolute; left: 0; bottom: -7px;
    width: 0; height: 2px; background: var(--accent); transition: width 0.3s ease;
  }
  .navlinks a:hover { opacity: 1; }
  .navlinks > a:not(.btn):hover::after,
  .nav-drop:hover > a::after { width: 100%; }

  /* Dropdown Servizi (pattern submenu del reference) */
  .nav-drop { position: relative; }
  .nav-drop > a { display: inline-flex; align-items: center; gap: 6px; }
  .caret { transition: transform 0.3s ease; }
  .nav-drop:hover .caret, .nav-drop:focus-within .caret { transform: rotate(180deg); }
  .drop-menu {
    position: absolute; top: calc(100% + 14px); left: -18px;
    min-width: 330px;
    background: var(--header-bg);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    color: var(--ink);
    border: 1px solid var(--hair-faint);
    border-radius: var(--radius-card);
    box-shadow: 0 22px 50px rgba(6, 27, 61, 0.16);
    padding: 10px;
    opacity: 0; visibility: hidden; transform: translateY(8px);
    transition: all 0.25s ease;
    z-index: 60;
  }
  .drop-menu::before {
    /* ponte invisibile per non perdere l'hover */
    content: ""; position: absolute; top: -14px; left: 0; right: 0; height: 14px;
  }
  .nav-drop:hover .drop-menu, .nav-drop:focus-within .drop-menu {
    opacity: 1; visibility: visible; transform: translateY(0);
  }
  .drop-item {
    display: flex; align-items: baseline; gap: 12px;
    padding: 11px 14px;
    font-size: 14.5px; font-weight: 600;
    border-radius: 2px;
    transition: background 0.25s ease, color 0.25s ease;
  }
  .drop-item:hover { background: var(--bg-2); color: var(--accent-text); }
  .drop-num {
    font-size: 10.5px; font-weight: 700; letter-spacing: 0.14em;
    color: var(--accent-text);
  }

  /* Mentoria: pill ORO sempre in evidenza (firma oro+blu) */
  .btn-gold {
    background: var(--gold);
    border-color: var(--gold);
    color: #081527;
    opacity: 1 !important;
    font-size: 13px; padding: 13px 24px;
  }
  .btn-gold:hover {
    background: var(--gold-soft);
    border-color: var(--gold-soft);
    color: #081527;
  }

  .head-actions { display: flex; align-items: center; gap: 12px; }

  .nav-cta, .nav-mentoria { display: none; }
  .desk-cta { font-size: 13px; padding: 13px 24px; }

  .menu-tog {
    display: none;
    font-family: var(--sans); font-size: 14px; font-weight: 700;
    letter-spacing: 0.1em; text-transform: uppercase;
    color: inherit;
    background: none; border: none; cursor: pointer; padding: 6px 2px;
  }

  @media (max-width: 980px) {
    .navlinks, .head-actions { display: none; }
    .menu-tog { display: block; }

    .navlinks.open {
      display: flex;
      position: absolute; top: calc(100% + 4px); right: 24px;
      flex-direction: column; align-items: flex-end; gap: 18px;
      background: var(--header-bg);
      backdrop-filter: blur(14px);
      -webkit-backdrop-filter: blur(14px);
      color: var(--ink);
      padding: 26px 30px;
      border: 1px solid var(--hair-faint);
      border-radius: var(--radius-card);
      max-height: calc(100vh - 110px);
      overflow-y: auto;
    }
    .nav-cta, .nav-mentoria { display: inline-block; margin-top: 6px; }

    /* Dropdown inline nel menu mobile */
    .nav-drop { display: flex; flex-direction: column; align-items: flex-end; }
    .drop-menu {
      position: static;
      opacity: 1; visibility: visible; transform: none;
      box-shadow: none; border: none;
      background: transparent;
      -webkit-backdrop-filter: none; backdrop-filter: none;
      padding: 8px 0 0;
      min-width: 0;
    }
    .drop-item { justify-content: flex-end; padding: 7px 0; font-size: 13.5px; }
    .caret { display: none; }
  }
</style>

<script>
  const tog = document.getElementById('menu-tog')!;
  const links = document.getElementById('navlinks')!;

  const setOpen = (open: boolean) => {
    links.classList.toggle('open', open);
    tog.setAttribute('aria-expanded', String(open));
    tog.setAttribute('aria-label', open ? 'Chiudi il menu' : 'Apri il menu');
    tog.textContent = open ? 'Chiudi' : 'Menu';
  };

  tog.addEventListener('click', () =>
    setOpen(!links.classList.contains('open'))
  );
  links.addEventListener('click', (e) => {
    if ((e.target as HTMLElement).closest('a')) setOpen(false);
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') setOpen(false);
  });
</script>
