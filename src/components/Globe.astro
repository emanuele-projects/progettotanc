---
/**
 * Globo COBE (WebGL a punti) — vista FISSA centrata sulla porzione
 * Europa + Golfo dove si trovano tutte le sedi. Non ruota da solo.
 * Sfondo trasparente (nessun riquadro): la sfera galleggia sulla
 * sezione. Marker su lat/lng reali; archi dorati dalla direzionale.
 * Se interactive, l'elenco sedi può centrare un punto via __globe.focus.
 */
interface Marker {
  lat: number;
  lng: number;
}
interface Props {
  id: string;
  markers: Marker[];
  primaryIndex?: number;
  interactive?: boolean;
  /** centro della vista fissa */
  centerLat?: number;
  centerLng?: number;
  label?: string;
}
const {
  id,
  markers,
  primaryIndex = -1,
  interactive = false,
  centerLat = 44,
  centerLng = 17,
  label = 'Globo delle sedi',
} = Astro.props;
---

<div class="globe-wrap">
  <canvas
    data-globe
    id={id}
    data-markers={JSON.stringify(markers)}
    data-primary={String(primaryIndex)}
    data-interactive={String(interactive)}
    data-center-lat={String(centerLat)}
    data-center-lng={String(centerLng)}
    role="img"
    aria-label={label}
  ></canvas>
</div>

<style>
  .globe-wrap {
    position: relative;
    width: 100%;
    aspect-ratio: 1;
    display: flex; align-items: center; justify-content: center;
  }
  .globe-wrap canvas {
    width: 100%; height: 100%;
    background: transparent;
  }
  .globe-wrap.is-interactive canvas { cursor: grab; touch-action: pan-y; }
  .globe-wrap.is-interactive canvas:active { cursor: grabbing; }
</style>

<script>
  import createGlobe from 'cobe';

  const GOLD: [number, number, number] = [0.76, 0.64, 0.36];      // #C2A35B
  const GOLD_SOFT: [number, number, number] = [0.85, 0.75, 0.52]; // #D8BE84
  const BASE: [number, number, number] = [0.16, 0.24, 0.42];      // navy dei punti
  const GLOW: [number, number, number] = [0.09, 0.15, 0.28];      // alone navy discreto

  const locationToAngles = (lat: number, lng: number): [number, number] => [
    Math.PI - ((lng * Math.PI) / 180 - Math.PI / 2),
    (lat * Math.PI) / 180,
  ];

  document.querySelectorAll<HTMLCanvasElement>('[data-globe]').forEach((canvas) => {
    const markerData: { lat: number; lng: number }[] = JSON.parse(canvas.dataset.markers || '[]');
    const primaryIdx = parseInt(canvas.dataset.primary || '-1', 10);
    const interactive = canvas.dataset.interactive === 'true';
    const centerLat = parseFloat(canvas.dataset.centerLat || '38');
    const centerLng = parseFloat(canvas.dataset.centerLng || '26');
    if (interactive) canvas.parentElement?.classList.add('is-interactive');

    const baseMarkers = (active: number) =>
      markerData.map((m, i) => ({
        location: [m.lat, m.lng] as [number, number],
        size: i === active ? 0.1 : i === primaryIdx ? 0.055 : 0.04,
        color: (i === active ? GOLD_SOFT : GOLD) as [number, number, number],
      }));

    // archi dalla sede direzionale alle altre
    const hqI = primaryIdx >= 0 ? primaryIdx : 0;
    const hq = markerData[hqI];
    const arcs = hq
      ? markerData
          .filter((_, i) => i !== hqI)
          .map((m) => ({
            from: [hq.lat, hq.lng] as [number, number],
            to: [m.lat, m.lng] as [number, number],
            color: GOLD as [number, number, number],
          }))
      : [];

    // vista FISSA centrata sulla porzione con tutte le sedi
    const [homePhi, homeTheta] = locationToAngles(centerLat, centerLng);
    let width = 0;
    let currentPhi = homePhi;
    let currentTheta = homeTheta;
    let focusTarget: [number, number] | null = null;
    let activeIdx = -1;
    let dragging = false;
    let pointerStartX = 0;
    let pointerStartY = 0;
    let phiAtStart = 0;
    let thetaAtStart = 0;

    const onResize = () => { width = canvas.offsetWidth; };
    addEventListener('resize', onResize);
    onResize();

    const globe = createGlobe(canvas, {
      devicePixelRatio: 2,
      width: width * 2,
      height: width * 2,
      phi: currentPhi,
      theta: currentTheta,
      dark: 1,
      diffuse: 1.2,
      mapSamples: 20000,
      mapBrightness: 5,
      baseColor: BASE,
      markerColor: GOLD,
      glowColor: GLOW,
      opacity: 0.9,
      markers: baseMarkers(-1),
      arcs,
      arcColor: GOLD,
      arcWidth: 0.35,
      arcHeight: 0.32,
    });

    // COBE ha bisogno di frame per disegnare: loop SENZA rotazione automatica
    let raf = 0;
    const tick = () => {
      if (focusTarget) {
        const [tPhi, tTheta] = focusTarget;
        const dPhi = ((tPhi - currentPhi + Math.PI * 3) % (Math.PI * 2)) - Math.PI;
        const dTheta = tTheta - currentTheta;
        currentPhi += dPhi * 0.09;
        currentTheta += dTheta * 0.09;
        if (Math.abs(dPhi) < 0.002 && Math.abs(dTheta) < 0.002) focusTarget = null;
      }
      globe.update({
        phi: currentPhi,
        theta: currentTheta,
        markers: baseMarkers(activeIdx),
        width: width * 2,
        height: width * 2,
      });
      raf = requestAnimationFrame(tick);
    };
    raf = requestAnimationFrame(tick);

    if (interactive) {
      canvas.addEventListener('pointerdown', (e) => {
        dragging = true;
        focusTarget = null;
        pointerStartX = e.clientX;
        pointerStartY = e.clientY;
        phiAtStart = currentPhi;
        thetaAtStart = currentTheta;
        canvas.setPointerCapture(e.pointerId);
      });
      canvas.addEventListener('pointermove', (e) => {
        if (!dragging) return;
        currentPhi = phiAtStart + (e.clientX - pointerStartX) / 140;
        currentTheta = Math.max(-0.6, Math.min(1.1, thetaAtStart + (e.clientY - pointerStartY) / 220));
      });
      const endDrag = () => { dragging = false; };
      canvas.addEventListener('pointerup', endDrag);
      canvas.addEventListener('pointercancel', endDrag);
    }

    (canvas as HTMLCanvasElement & { __globe?: unknown }).__globe = {
      focus(lat: number, lng: number, idx: number) {
        focusTarget = locationToAngles(lat, lng);
        activeIdx = idx;
      },
      reset() {
        focusTarget = [homePhi, homeTheta];
        activeIdx = -1;
      },
    };

    addEventListener('pagehide', () => {
      cancelAnimationFrame(raf);
      globe.destroy();
    }, { once: true });
  });
</script>
