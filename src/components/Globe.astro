---
/**
 * Porzione di globo in prospettiva (d3-geo, calcolata a build-time).
 * NON è più una mappa interattiva: è un elemento illustrativo, statico,
 * inquadrato come una finestra su una porzione di sfera. La curvatura
 * della graticola dà la prospettiva; piccoli punti oro segnano le città
 * (senza etichette né collegamenti). Le informazioni sulle sedi vivono
 * nei blocchi accanto, divisi per tipologia.
 */
import { geoOrthographic, geoPath, geoGraticule10, geoDistance } from 'd3-geo';
import { feature } from 'topojson-client';
import land110m from 'world-atlas/land-110m.json';

interface Marker {
  lat: number;
  lng: number;
  city: string;
  primary?: boolean;
}
interface Props {
  markers: Marker[];
  /** centro della proiezione (leggermente a sud del cluster per dare prospettiva) */
  centerLat?: number;
  centerLng?: number;
  /** raggio della sfera in unità viewBox: grande = la sfera riempie l'inquadratura */
  scale?: number;
  viewW?: number;
  viewH?: number;
  /** posizione del centro-proiezione nel riquadro (frazione di viewW/viewH) */
  offsetX?: number;
  offsetY?: number;
  label?: string;
}
const {
  markers,
  centerLat = 38,
  centerLng = 24,
  scale = 470,
  viewW = 560,
  viewH = 520,
  offsetX = 0.5,
  offsetY = 0.42,
  label = 'Le sedi tra Europa e Golfo',
} = Astro.props;

const translate: [number, number] = [viewW * offsetX, viewH * offsetY];

const projection = geoOrthographic()
  .rotate([-centerLng, -centerLat])
  .scale(scale)
  .translate(translate)
  .clipAngle(90);

const path = geoPath(projection);

// @ts-expect-error — topojson land object
const landGeo = feature(land110m, land110m.objects.land);
const landPath = path(landGeo) ?? '';
const graticulePath = path(geoGraticule10()) ?? '';

const centerCoord: [number, number] = [centerLng, centerLat];

// punti città sul lato visibile della sfera
const dots = markers
  .map((m, i) => {
    const p = projection([m.lng, m.lat]);
    const visible = p && geoDistance([m.lng, m.lat], centerCoord) < Math.PI / 2;
    return p && visible ? { ...m, i, x: p[0], y: p[1] } : null;
  })
  .filter((p): p is NonNullable<typeof p> => p !== null);
---

<svg viewBox={`0 0 ${viewW} ${viewH}`} role="img" aria-label={label} class="globe-svg">
  <defs>
    <radialGradient id="fr-globe-sphere" cx="40%" cy="34%" r="80%">
      <stop offset="0" stop-color="#183255" />
      <stop offset="0.6" stop-color="#0C1E3B" />
      <stop offset="1" stop-color="#08152A" />
    </radialGradient>
    <radialGradient id="fr-globe-vignette" cx="50%" cy="50%" r="62%">
      <stop offset="0.66" stop-color="#000000" stop-opacity="0" />
      <stop offset="1" stop-color="#050C18" stop-opacity="0.85" />
    </radialGradient>
  </defs>

  <!-- superficie della sfera (grande: riempie il riquadro) -->
  <circle cx={translate[0]} cy={translate[1]} r={scale} fill="url(#fr-globe-sphere)" />

  <!-- graticola: la sua curvatura dà la prospettiva -->
  <path d={graticulePath} fill="none" stroke="var(--gold)" stroke-width="0.7" stroke-opacity="0.24" />

  <!-- terre emerse in silhouette -->
  <path d={landPath} fill="#2E5691" fill-opacity="0.95" stroke="#4A72B0" stroke-width="0.5" stroke-opacity="0.6" />

  <!-- vignettatura per profondità -->
  <circle cx={translate[0]} cy={translate[1]} r={scale} fill="url(#fr-globe-vignette)" />

  <!-- punti città (solo segnaposto, nessuna etichetta) -->
  <g class="dots">
    {dots.map((d) => (
      <g class:list={['dot', { primary: d.primary }]} transform={`translate(${d.x} ${d.y})`}>
        <title>{d.city}</title>
        <circle class="dot-glow" r="12" />
        <circle class="dot-ring" r={d.primary ? 8 : 6} />
        <circle class="dot-core" r={d.primary ? 3.4 : 2.6} />
      </g>
    ))}
  </g>
</svg>

<style>
  .globe-svg { width: 100%; height: 100%; display: block; }

  .dot-glow { fill: var(--gold-soft); opacity: 0.14; }
  .dot-ring { fill: none; stroke: var(--gold); stroke-width: 1; opacity: 0.5; }
  .dot-core { fill: var(--gold-soft); }
  .dot.primary .dot-core { fill: #FFFFFF; }
  .dot.primary .dot-ring { stroke: var(--gold-soft); opacity: 0.75; }
  .dot.primary .dot-glow { opacity: 0.22; }
</style>
