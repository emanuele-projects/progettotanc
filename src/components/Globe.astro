---
/**
 * Porzione di globo in prospettiva (d3-geo, calcolata a build-time).
 * NON è una mappa interattiva: è un elemento illustrativo statico. La
 * sfera sfuma verso i bordi (maschera radiale) così da perdersi nello
 * sfondo, senza cornice né riquadro. I punti oro segnano le città; al
 * passaggio del mouse mostrano nome + tipologia della sede (non cliccabili).
 */
import { geoOrthographic, geoPath, geoGraticule10, geoDistance } from 'd3-geo';
import { feature } from 'topojson-client';
import land110m from 'world-atlas/land-110m.json';

interface Marker {
  lat: number;
  lng: number;
  city: string;
  typeLabel?: string;
  primary?: boolean;
}
interface Props {
  markers: Marker[];
  centerLat?: number;
  centerLng?: number;
  scale?: number;
  viewW?: number;
  viewH?: number;
  offsetX?: number;
  offsetY?: number;
  label?: string;
}
const {
  markers,
  centerLat = 44,
  centerLng = 20,
  scale = 485,
  viewW = 560,
  viewH = 520,
  offsetX = 0.5,
  offsetY = 0.5,
  label = 'Le sedi tra Europa e Golfo',
} = Astro.props;

const translate: [number, number] = [viewW * offsetX, viewH * offsetY];

const projection = geoOrthographic()
  .rotate([-centerLng, -centerLat])
  .scale(scale)
  .translate(translate)
  .clipAngle(90);

const path = geoPath(projection);

// @ts-expect-error — topojson land object
const landGeo = feature(land110m, land110m.objects.land);
const landPath = path(landGeo) ?? '';
const graticulePath = path(geoGraticule10()) ?? '';

const centerCoord: [number, number] = [centerLng, centerLat];

// raggio della dissolvenza (la sfera vera è enorme: qui definiamo dove sfuma)
const fadeR = Math.min(viewW, viewH) * 0.58;

const dots = markers
  .map((m, i) => {
    const p = projection([m.lng, m.lat]);
    const visible = p && geoDistance([m.lng, m.lat], centerCoord) < Math.PI / 2;
    return p && visible ? { ...m, i, x: p[0], y: p[1] } : null;
  })
  .filter((p): p is NonNullable<typeof p> => p !== null);
---

<svg viewBox={`0 0 ${viewW} ${viewH}`} role="img" aria-label={label} class="globe-svg">
  <defs>
    <radialGradient id="fr-globe-sphere" cx="42%" cy="36%" r="62%">
      <stop offset="0" stop-color="#1B3A63" />
      <stop offset="0.6" stop-color="#0D2140" />
      <stop offset="1" stop-color="#0A1B33" />
    </radialGradient>
    <!-- dissolvenza verso i bordi: la sfera si perde nello sfondo -->
    <radialGradient id="fr-globe-fade" gradientUnits="userSpaceOnUse"
      cx={translate[0]} cy={translate[1]} r={fadeR}>
      <stop offset="0" stop-color="#fff" />
      <stop offset="0.62" stop-color="#fff" />
      <stop offset="1" stop-color="#000" />
    </radialGradient>
    <mask id="fr-globe-mask">
      <rect x="0" y="0" width={viewW} height={viewH} fill="url(#fr-globe-fade)" />
    </mask>
  </defs>

  <!-- corpo del globo, mascherato per sfumare ai bordi -->
  <g mask="url(#fr-globe-mask)">
    <circle cx={translate[0]} cy={translate[1]} r={scale} fill="url(#fr-globe-sphere)" />
    <path d={graticulePath} fill="none" stroke="var(--gold)" stroke-width="0.7" stroke-opacity="0.22" />
    <path d={landPath} fill="#2E5691" fill-opacity="0.95" stroke="#4A72B0" stroke-width="0.5" stroke-opacity="0.6" />
  </g>

  <!-- punti città + etichetta (nome + tipologia) al passaggio del mouse -->
  <g class="dots">
    {dots.map((d) => (
      <g class:list={['dot', { primary: d.primary }]} transform={`translate(${d.x} ${d.y})`}>
        <title>{d.city}{d.typeLabel ? ` — ${d.typeLabel}` : ''}</title>
        <circle class="dot-glow" r="14" />
        <circle class="dot-ring" r={d.primary ? 8 : 6} />
        <circle class="dot-core" r={d.primary ? 3.4 : 2.6} />
        <g class="dot-label">
          <text class="dl-city" y="26" text-anchor="middle">{d.city}</text>
          {d.typeLabel && <text class="dl-type" y="41" text-anchor="middle">{d.typeLabel}</text>}
        </g>
      </g>
    ))}
  </g>
</svg>

<style>
  .globe-svg { width: 100%; height: 100%; display: block; overflow: visible; }

  .dot { cursor: default; }
  .dot-glow { fill: var(--gold-soft); opacity: 0.16; transition: opacity 0.3s ease, r 0.3s ease; }
  .dot-ring { fill: none; stroke: var(--gold); stroke-width: 1; opacity: 0.55; }
  .dot-core { fill: var(--gold-soft); }
  .dot.primary .dot-core { fill: #FFFFFF; }
  .dot.primary .dot-ring { stroke: var(--gold-soft); opacity: 0.8; }
  .dot.primary .dot-glow { opacity: 0.24; }
  .dot:hover .dot-glow { opacity: 0.4; }

  /* etichetta: nascosta, appare all'hover del punto */
  .dot-label { opacity: 0; transition: opacity 0.25s ease; pointer-events: none; }
  .dot:hover .dot-label { opacity: 1; }
  .dl-city {
    font-family: var(--disp); font-size: 15px; font-weight: 700;
    fill: #FFFFFF; paint-order: stroke; stroke: #08152A; stroke-width: 4px;
    stroke-linejoin: round;
  }
  .dl-type {
    font-family: var(--sans); font-size: 9.5px; font-weight: 700;
    letter-spacing: 0.14em; text-transform: uppercase;
    fill: var(--gold-soft); paint-order: stroke; stroke: #08152A; stroke-width: 3.5px;
    stroke-linejoin: round;
  }
</style>
