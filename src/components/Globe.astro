---
/**
 * Globo 3D INTERATTIVO (canvas + d3-geo ortografico, client-side).
 * - Trascinabile per ruotare (nessuna autorotazione)
 * - Click su un pin: il globo RUOTA (GSAP) fino a centrare la sede,
 *   poi si apre la scheda (tipologia + nota)
 * - Estetica: notte navy, airglow oro sul limbo, stelle, pin oro a
 *   goccia con etichetta (lati assegnati per evitare sovrapposizioni)
 * - Nessun elemento superfluo: niente luci-città né aree evidenziate
 */
interface Marker {
  lat: number;
  lng: number;
  city: string;
  country: string;
  typeLabel: string;
  note?: string;
  primary?: boolean;
}
interface Props {
  markers: Marker[];
  label?: string;
}
const { markers, label = 'Globo interattivo delle sedi: trascina per ruotare, tocca una sede per centrarla' } = Astro.props;
---

<figure class="globe-scene" data-globe-scene role="group" aria-label={label}>
  <canvas class="gs-canvas" aria-hidden="true"></canvas>

  <!-- pin cliccabili: posizionati dal client a ogni frame -->
  <div class="gs-pins">
    {markers.map((p) => (
      <button
        type="button"
        class:list={['gpin', { primary: p.primary }]}
        style="left:-999px; top:-999px"
        data-city={p.city}
        data-type={p.typeLabel}
        data-country={p.country}
        data-note={p.note ?? ''}
        data-lat={String(p.lat)}
        data-lng={String(p.lng)}
        aria-label={`${p.city} — ${p.typeLabel}`}
      >
        <span class="gpin-halo" aria-hidden="true"></span>
        <svg class="gpin-glyph" viewBox="0 0 24 32" aria-hidden="true">
          <path class="gg-body" d="M12 31C12 31 2 18.8 2 11a10 10 0 1 1 20 0c0 7.8-10 20-10 20Z" />
          <circle class="gg-hole" cx="12" cy="11" r="4" />
        </svg>
        <span class="gpin-label">{p.city}</span>
      </button>
    ))}
  </div>

  <!-- scheda della sede -->
  <div class="gs-card" data-scene-card hidden>
    <span class="gc-type" data-c-type></span>
    <h3 class="gc-city" data-c-city></h3>
    <p class="gc-country" data-c-country></p>
    <p class="gc-note" data-c-note></p>
  </div>

  <!-- suggerimento d'uso -->
  <span class="gs-hint" data-hint>Trascina per ruotare · tocca una sede per centrarla</span>

  <!-- dissolvenza dei bordi nello sfondo della sezione -->
  <div class="gs-edge gs-edge-l" aria-hidden="true"></div>
  <div class="gs-edge gs-edge-r" aria-hidden="true"></div>
  <div class="gs-edge gs-edge-b" aria-hidden="true"></div>
  <div class="gs-edge gs-edge-t" aria-hidden="true"></div>

  <figcaption class="sr-only">
    {markers.map((p) => `${p.city} (${p.typeLabel})`).join(', ')}.
  </figcaption>
</figure>

<style define:vars={{ sceneBg: '#050B16' }}>
  .globe-scene {
    position: relative;
    aspect-ratio: 1000 / 560;
    width: 100%;
    overflow: hidden;
  }
  .gs-canvas {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    display: block;
    cursor: grab;
    touch-action: pan-y;
  }
  .gs-canvas.dragging { cursor: grabbing; }

  /* pin */
  .gs-pins { position: absolute; inset: 0; pointer-events: none; }
  .gpin {
    position: absolute;
    transform: translate(-50%, -100%) scale(var(--pz, 1));
    transform-origin: 50% 100%;
    pointer-events: auto;
    background: none; border: none; padding: 0;
    cursor: pointer;
    display: block;
    filter: drop-shadow(0 3px 6px rgba(0, 0, 0, 0.55));
    transition: opacity 0.25s ease;
  }
  .gpin[data-far] { opacity: 0; pointer-events: none; }
  .gpin-glyph {
    display: block;
    width: 24px; height: 32px;
    transition: transform 0.3s ease;
    transform-origin: 50% 100%;
  }
  .gg-body { fill: #C9A85C; stroke: #6B531F; stroke-width: 0.8; }
  .gg-hole { fill: #0A1322; }
  .gpin.primary .gg-body { fill: #DCBE7C; }
  .gpin:hover .gpin-glyph, .gpin.active .gpin-glyph { transform: scale(1.14); }
  .gpin:focus-visible { outline: none; }
  .gpin:focus-visible .gpin-glyph { transform: scale(1.14); }
  .gpin:focus-visible .gpin-label { text-decoration: underline; text-underline-offset: 3px; }

  .gpin-halo {
    position: absolute;
    left: 50%; bottom: -3px;
    width: 14px; height: 5px;
    transform: translateX(-50%);
    border-radius: 50%;
    background: radial-gradient(ellipse at center, rgba(233, 201, 125, 0.55), transparent 70%);
  }
  @media (prefers-reduced-motion: no-preference) {
    .gpin::after {
      content: "";
      position: absolute;
      left: 50%; bottom: -6px;
      width: 12px; height: 12px;
      border: 1px solid rgba(226, 190, 116, 0.55);
      border-radius: 50%;
      transform: translateX(-50%) scale(0.4);
      animation: gs-pulse 2.8s ease-out infinite;
    }
    .gpin.primary::after { animation-duration: 2.2s; }
  }
  @keyframes gs-pulse {
    0% { transform: translateX(-50%) scale(0.35) scaleY(0.45); opacity: 0.8; }
    100% { transform: translateX(-50%) scale(2.1) scaleY(0.45); opacity: 0; }
  }

  .gpin-label {
    position: absolute;
    font-family: var(--disp);
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    color: #F5EFDF;
    white-space: nowrap;
    text-shadow: 0 1px 10px rgba(0, 0, 0, 0.9), 0 0 3px rgba(0, 0, 0, 0.9);
    pointer-events: none;
  }
  /* lato dell'etichetta per sede: evita sovrapposizioni nel cluster Italia */
  .gpin .gpin-label { left: calc(100% + 7px); top: 5px; }
  .gpin[data-side="left"] .gpin-label { left: auto; right: calc(100% + 7px); }
  .gpin[data-side="top"] .gpin-label { left: 50%; right: auto; top: -18px; transform: translateX(-50%); }
  .gpin[data-side="bottom"] .gpin-label { left: 50%; right: auto; top: calc(100% + 3px); transform: translateX(-50%); }

  /* scheda */
  .gs-card {
    position: absolute;
    z-index: 60;
    width: min(250px, 72vw);
    transform: translate(-50%, -100%);
    background: rgba(9, 20, 39, 0.96);
    border: 1px solid rgba(194, 163, 91, 0.4);
    border-left: 3px solid #C2A35B;
    border-radius: 2px;
    padding: 16px 18px 14px;
    box-shadow: 0 22px 50px rgba(0, 0, 0, 0.55);
    pointer-events: none;
  }
  .gs-card[data-pos="below"] { transform: translate(-50%, 0); }
  .gs-card[hidden] { display: none; }
  .gc-type {
    font-family: var(--sans); font-size: 9.5px; font-weight: 700;
    letter-spacing: 0.2em; text-transform: uppercase; color: #D8BE84;
  }
  .gc-city { font-family: var(--disp); font-size: 22px; font-weight: 800; color: #FFFFFF; margin: 4px 0 0; }
  .gc-country {
    font-family: var(--sans); font-size: 10.5px; font-weight: 600;
    letter-spacing: 0.14em; text-transform: uppercase; color: rgba(236, 229, 214, 0.55);
    margin-top: 2px;
  }
  .gc-note { font-size: 14.5px; line-height: 1.5; color: rgba(236, 229, 214, 0.8); margin-top: 10px; }

  /* hint */
  .gs-hint {
    position: absolute;
    left: 50%; bottom: 12px;
    transform: translateX(-50%);
    z-index: 3;
    font-family: var(--sans); font-size: 10.5px; font-weight: 600;
    letter-spacing: 0.16em; text-transform: uppercase;
    color: rgba(236, 229, 214, 0.5);
    background: rgba(5, 11, 22, 0.55);
    padding: 6px 14px;
    border: 1px solid rgba(236, 229, 214, 0.12);
    border-radius: 20px;
    pointer-events: none;
    transition: opacity 0.5s ease;
    white-space: nowrap;
  }
  .gs-hint.hide { opacity: 0; }

  /* bordi che si dissolvono nello sfondo della sezione */
  .gs-edge { position: absolute; pointer-events: none; z-index: 55; }
  .gs-edge-l { inset: 0 auto 0 0; width: 7%; background: linear-gradient(to right, var(--sceneBg), transparent); }
  .gs-edge-r { inset: 0 0 0 auto; width: 7%; background: linear-gradient(to left, var(--sceneBg), transparent); }
  .gs-edge-b { inset: auto 0 0 0; height: 12%; background: linear-gradient(to top, var(--sceneBg), transparent); }
  .gs-edge-t { inset: 0 0 auto 0; height: 7%; background: linear-gradient(to bottom, var(--sceneBg), transparent); }

  .sr-only {
    position: absolute; width: 1px; height: 1px;
    margin: -1px; padding: 0; overflow: hidden;
    clip: rect(0 0 0 0); white-space: nowrap; border: 0;
  }

  @media (max-width: 700px) {
    .globe-scene { aspect-ratio: 1 / 0.9; }
    .gpin-label { font-size: 11px; letter-spacing: 0.09em; }
  }
</style>

<script>
  import { geoOrthographic, geoPath, geoGraticule10, geoDistance } from 'd3-geo';
  import { feature, mesh } from 'topojson-client';
  import land110m from 'world-atlas/land-110m.json';
  import countries110m from 'world-atlas/countries-110m.json';
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // @ts-expect-error — topojson non tipizzato
  const LAND = feature(land110m, land110m.objects.land);
  // @ts-expect-error — topojson non tipizzato
  const BORDERS = mesh(countries110m, countries110m.objects.countries, (a, b) => a !== b);
  const GRATICULE = geoGraticule10();

  const mulberry32 = (seed: number) => () => {
    seed |= 0;
    seed = (seed + 0x6d2b79f5) | 0;
    let t = Math.imul(seed ^ (seed >>> 15), 1 | seed);
    t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t;
    return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
  };

  /* lato dell'etichetta per ogni sede (ordine leggibile nel cluster) */
  const LABEL_SIDE: Record<string, string> = {
    Torino: 'left',
    Milano: 'top',
    Montecarlo: 'bottom',
    Roma: 'right',
    Cracovia: 'right',
    Vilnius: 'top',
    Dubai: 'right',
  };

  document.querySelectorAll<HTMLElement>('[data-globe-scene]').forEach((scene) => {
    const canvas = scene.querySelector<HTMLCanvasElement>('.gs-canvas')!;
    const ctx = canvas.getContext('2d')!;
    const pins = [...scene.querySelectorAll<HTMLButtonElement>('.gpin')];
    const card = scene.querySelector<HTMLElement>('[data-scene-card]');
    const hint = scene.querySelector<HTMLElement>('[data-hint]');

    pins.forEach((p) => {
      const side = LABEL_SIDE[p.dataset.city ?? ''] ?? 'right';
      if (side !== 'right') p.dataset.side = side;
    });

    /* ---------- proiezione e stato ----------
       Inquadratura iniziale: zoom sulla zona delle sedi, composizione
       alta (i pin nella fascia centrale), leggero rollio come nel
       riferimento. Il limbo con l'airglow resta visibile in alto. */
    const projection = geoOrthographic().clipAngle(90);
    const rot: [number, number, number] = [-18, -16, 22];
    let W = 0, H = 0, R = 0, CX = 0, CY = 0, DPR = 1, anchorY = 0;
    let stars: { x: number; y: number; r: number; o: number }[] = [];

    const resize = () => {
      const b = scene.getBoundingClientRect();
      W = Math.max(300, b.width);
      H = Math.max(200, b.height);
      DPR = Math.min(2, window.devicePixelRatio || 1);
      canvas.width = Math.round(W * DPR);
      canvas.height = Math.round(H * DPR);
      /* unità di design: la composizione è pensata per un riquadro
         1000×560; D la riproduce identica in qualsiasi contenitore,
         centrata verticalmente */
      const D = Math.min(H, W * 0.56);
      R = D * 1.28;
      CX = W * 0.5;
      CY = (H - D) / 2 + D * 1.02;
      anchorY = (H - D) / 2 + D * 0.52;
      projection.scale(R).translate([CX, CY]);
      const rnd = mulberry32(77);
      stars = Array.from({ length: 70 }, () => {
        const x = rnd() * W, y = rnd() * H;
        return { x, y, r: 0.5 + rnd() * 0.9, o: 0.1 + rnd() * 0.4 };
      }).filter((s) => Math.hypot(s.x - CX, s.y - CY) > R + 10);
      render();
    };

    const path = geoPath(projection, ctx);
    const visible = (lng: number, lat: number) =>
      geoDistance([lng, lat], [-rot[0], -rot[1]]) < Math.PI / 2 - 0.02;

    /* ---------- disegno (on demand, nessun loop) ---------- */
    const render = () => {
      projection.rotate(rot);
      ctx.setTransform(DPR, 0, 0, DPR, 0, 0);
      ctx.clearRect(0, 0, W, H);

      // stelle
      for (const s of stars) {
        ctx.globalAlpha = s.o;
        ctx.fillStyle = '#EADFC4';
        ctx.beginPath();
        ctx.arc(s.x, s.y, s.r, 0, Math.PI * 2);
        ctx.fill();
      }
      ctx.globalAlpha = 1;

      // disco: mare notturno (più chiaro verso il limbo)
      const sea = ctx.createLinearGradient(0, CY - R, 0, H);
      sea.addColorStop(0, '#122846');
      sea.addColorStop(0.4, '#081527');
      sea.addColorStop(1, '#030915');
      ctx.fillStyle = sea;
      ctx.beginPath();
      ctx.arc(CX, CY, R, 0, Math.PI * 2);
      ctx.fill();

      // graticola
      ctx.beginPath();
      path(GRATICULE);
      ctx.strokeStyle = 'rgba(194, 163, 91, 0.13)';
      ctx.lineWidth = 0.6;
      ctx.stroke();

      // terre
      ctx.beginPath();
      path(LAND);
      ctx.fillStyle = '#1D3560';
      ctx.fill();
      ctx.strokeStyle = 'rgba(78, 123, 180, 0.5)';
      ctx.lineWidth = 0.7;
      ctx.stroke();

      // confini
      ctx.beginPath();
      path(BORDERS);
      ctx.strokeStyle = 'rgba(51, 87, 142, 0.55)';
      ctx.lineWidth = 0.5;
      ctx.stroke();

      // airglow sul bordo del disco
      ctx.save();
      ctx.strokeStyle = 'rgba(194, 163, 91, 0.20)';
      ctx.lineWidth = 9;
      ctx.shadowColor = 'rgba(214, 178, 106, 0.8)';
      ctx.shadowBlur = 26;
      ctx.beginPath();
      ctx.arc(CX, CY, R + 1, 0, Math.PI * 2);
      ctx.stroke();
      ctx.strokeStyle = 'rgba(232, 200, 122, 0.5)';
      ctx.lineWidth = 2.6;
      ctx.shadowBlur = 10;
      ctx.stroke();
      ctx.strokeStyle = 'rgba(242, 215, 148, 0.9)';
      ctx.lineWidth = 1.1;
      ctx.shadowBlur = 0;
      ctx.stroke();
      ctx.restore();

      // pin HTML (ordinati: i più a sud sopra)
      for (const pin of pins) {
        const lng = parseFloat(pin.dataset.lng ?? '0');
        const lat = parseFloat(pin.dataset.lat ?? '0');
        if (!visible(lng, lat)) {
          pin.setAttribute('data-far', '');
          continue;
        }
        pin.removeAttribute('data-far');
        const p = projection([lng, lat]);
        if (!p) continue;
        const d = geoDistance([lng, lat], [-rot[0], -rot[1]]);
        const pz = 0.8 + 0.28 * Math.cos(d);
        pin.style.left = `${((p[0] / W) * 100).toFixed(3)}%`;
        pin.style.top = `${((p[1] / H) * 100).toFixed(3)}%`;
        pin.style.zIndex = String(10 + Math.round((p[1] / H) * 40));
        pin.style.setProperty('--pz', pz.toFixed(3));
      }
    };

    /* ---------- rotazione animata verso una sede ---------- */
    let focusTween: gsap.core.Tween | null = null;

    const rotationFor = (lng: number, lat: number): [number, number] => {
      // ancora di messa a fuoco: leggermente sopra il centro della composizione
      const anchor: [number, number] = [W * 0.5, anchorY];
      let r0 = rot[0], r1 = rot[1];
      // 3 iterazioni: con il rollio la soluzione converge subito
      for (let i = 0; i < 3; i++) {
        projection.rotate([r0, r1, rot[2]]);
        const inv = projection.invert?.(anchor);
        if (!inv || !isFinite(inv[0]) || !isFinite(inv[1])) break;
        let dl = lng - inv[0];
        dl = ((dl + 540) % 360) - 180;
        const df = lat - inv[1];
        r0 -= dl;
        r1 = Math.max(-80, Math.min(80, r1 - df));
      }
      projection.rotate(rot);
      return [r0, r1];
    };

    const focusOn = (pin: HTMLButtonElement, then?: () => void) => {
      const lng = parseFloat(pin.dataset.lng ?? '0');
      const lat = parseFloat(pin.dataset.lat ?? '0');
      const [tl, tp] = rotationFor(lng, lat);
      focusTween?.kill();
      if (reduced) {
        rot[0] = tl; rot[1] = tp;
        render();
        then?.();
        return;
      }
      const st = { l: rot[0], p: rot[1] };
      focusTween = gsap.to(st, {
        l: tl,
        p: tp,
        duration: 0.9,
        ease: 'power2.inOut',
        onUpdate: () => {
          rot[0] = st.l;
          rot[1] = st.p;
          render();
        },
        onComplete: () => {
          focusTween = null;
          then?.();
        },
      });
    };

    /* ---------- drag per ruotare ---------- */
    let dragging = false;
    let px = 0, py = 0;
    const onDown = (e: PointerEvent) => {
      focusTween?.kill();
      focusTween = null;
      dragging = true;
      px = e.clientX; py = e.clientY;
      canvas.classList.add('dragging');
      canvas.setPointerCapture(e.pointerId);
      hint?.classList.add('hide');
      closeCard();
    };
    const onMove = (e: PointerEvent) => {
      if (!dragging) return;
      const k = 0.22 * (300 / R) * 1.4;
      rot[0] += (e.clientX - px) * k;
      rot[1] = Math.max(-80, Math.min(80, rot[1] - (e.clientY - py) * k));
      px = e.clientX; py = e.clientY;
      render();
    };
    const onUp = (e: PointerEvent) => {
      dragging = false;
      canvas.classList.remove('dragging');
      try { canvas.releasePointerCapture(e.pointerId); } catch { /* già rilasciato */ }
    };
    canvas.addEventListener('pointerdown', onDown);
    canvas.addEventListener('pointermove', onMove);
    canvas.addEventListener('pointerup', onUp);
    canvas.addEventListener('pointercancel', onUp);

    /* ---------- scheda ---------- */
    const closeCard = () => {
      if (!card) return;
      card.hidden = true;
      pins.forEach((p) => p.classList.remove('active'));
    };

    const openCard = (pin: HTMLButtonElement) => {
      if (!card) return;
      const { city = '', type = '', country = '', note = '' } = pin.dataset;
      (card.querySelector('[data-c-type]') as HTMLElement).textContent = type;
      (card.querySelector('[data-c-city]') as HTMLElement).textContent = city;
      (card.querySelector('[data-c-country]') as HTMLElement).textContent = country;
      (card.querySelector('[data-c-note]') as HTMLElement).textContent = note;
      pins.forEach((p) => p.classList.toggle('active', p === pin));
      const pxv = parseFloat(pin.style.left);
      const pyv = parseFloat(pin.style.top);
      const above = pyv >= 42;
      card.dataset.pos = above ? 'above' : 'below';
      card.style.left = `${Math.min(Math.max(pxv, 15), 85)}%`;
      card.style.top = above ? `${pyv - 8}%` : `${pyv + 5}%`;
      card.hidden = false;
      const yp = above ? -100 : 0;
      if (!reduced) {
        gsap.fromTo(
          card,
          { opacity: 0, xPercent: -50, yPercent: yp, y: above ? 10 : -10 },
          { opacity: 1, xPercent: -50, yPercent: yp, y: 0, duration: 0.35, ease: 'power2.out' }
        );
      } else {
        gsap.set(card, { xPercent: -50, yPercent: yp, y: 0, opacity: 1 });
      }
    };

    pins.forEach((pin) => {
      pin.addEventListener('click', (e) => {
        e.stopPropagation();
        hint?.classList.add('hide');
        closeCard();
        // il globo ruota fino a centrare la sede, poi si apre la scheda
        focusOn(pin, () => openCard(pin));
      });
    });
    scene.addEventListener('click', (e) => {
      if (!(e.target as HTMLElement).closest('.gpin, [data-scene-card]')) closeCard();
    });
    window.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeCard();
    });

    /* ---------- ingresso pin (solo opacity: il transform CSS
         àncora il pin e non va toccato da GSAP) ---------- */
    if (!reduced && pins.length) {
      gsap.from(pins, {
        opacity: 0,
        duration: 0.8,
        ease: 'power2.out',
        stagger: 0.1,
        scrollTrigger: { trigger: scene, start: 'top 78%' },
        clearProps: 'opacity',
      });
    }

    new ResizeObserver(resize).observe(scene);
    resize();
  });
</script>
