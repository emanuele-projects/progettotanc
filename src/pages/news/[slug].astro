---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import CtaBand from '../../components/sections/CtaBand.astro';
import { getPosts, formatDate, type Post } from '../../lib/wp';

export async function getStaticPaths() {
  const posts = await getPosts();
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

interface Props {
  post: Post;
}
const { post } = Astro.props;
const dateLabel = `${formatDate(post.date)}${post.author ? ` · ${post.author}` : ''}`;
---

<BaseLayout
  theme="light"
  title={`${post.title} — Fulvio Rossi Plus`}
  description={post.excerpt}
  ogImage={post.featuredImage?.url}
>
  <article>
    <PageHero eyebrow={dateLabel} photo={post.featuredImage?.url} art="editorial">
      {post.title}
    </PageHero>

    <div class="wrap">
      <div class="post-content" data-reveal set:html={post.contentHtml} />
    </div>
  </article>

  <CtaBand
    lead="Un confronto riservato per mettere a fuoco insieme il valore da liberare e le mosse da fare."
  >
    <Fragment slot="title">Pronti a incontrare<br />i vostri <em>advisor?</em></Fragment>
  </CtaBand>
</BaseLayout>

<style>
  .post-content {
    max-width: 720px;
    padding: 70px 0 100px;
  }
  .post-content :global(p) {
    font-size: 20px; line-height: 1.75; color: var(--ink-dim);
    margin-bottom: 26px;
  }
  .post-content :global(h2) { font-size: 32px; margin: 46px 0 18px; }
  .post-content :global(h3) { font-size: 25px; margin: 38px 0 14px; }
  .post-content :global(a) {
    color: var(--accent-text);
    border-bottom: 1px solid var(--hair);
  }
  .post-content :global(blockquote) {
    font-family: var(--disp); font-size: 25px;
    line-height: 1.45; color: var(--ink);
    border-left: 2px solid var(--accent);
    padding-left: 26px; margin: 38px 0;
  }
  .post-content :global(ul), .post-content :global(ol) { padding-left: 24px; margin-bottom: 26px; }
  .post-content :global(li) { font-size: 19px; line-height: 1.7; color: var(--ink-dim); margin-bottom: 8px; }
  .post-content :global(img) { border: 1px solid var(--hair-faint); margin: 30px 0; }
</style>
