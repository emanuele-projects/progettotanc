---
/**
 * La pagina Sedi è confluita in "Team & Sedi" (/team). Manteniamo questo
 * URL come reindirizzamento per non rompere link esistenti. url() rende
 * la destinazione corretta anche con base path (GitHub Pages).
 */
import { url } from '../lib/url';
const target = url('/team/');
---

<!doctype html>
<html lang="it">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta http-equiv="refresh" content={`0; url=${target}`} />
    <link rel="canonical" href={target} />
    <meta name="robots" content="noindex" />
    <title>Sedi — Fulvio Rossi Plus</title>
  </head>
  <body>
    <p>La pagina Sedi è confluita in <a href={target}>Team &amp; Sedi</a>.</p>
  </body>
</html>
