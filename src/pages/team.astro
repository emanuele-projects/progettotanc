---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import BrandArt from '../components/BrandArt.astro';
import CtaBand from '../components/sections/CtaBand.astro';
import { team } from '../data/team';
---

<BaseLayout
  theme="light"
  title="Il team — Fulvio Rossi Plus"
  description="Una squadra multidisciplinare che risponde a voi: fiscalisti, legali, revisori e business coach sotto un'unica regìa."
>
  <PageHero
    eyebrow="Lo studio"
    art="portrait"
    lead="La fiducia nasce dai volti. Una squadra multidisciplinare — fiscalisti, legali, revisori, business coach — che risponde a voi."
  >
    Le persone, <em>prima di tutto</em>
  </PageHero>

  <section class="team-page">
    <div class="wrap">
      <div class="team-grid">
        {team.map((m) => (
          <div class="member" data-reveal>
            <div class="member-photo">
              <BrandArt variant="portrait" ratio="4 / 5" label={m.note} />
            </div>
            <div class="member-body">
              <h3>{m.name}</h3>
              <div class="pos">{m.role}</div>
              <div class="note">{m.note}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CtaBand
    lead="Un confronto riservato, senza impegno: mettiamo a fuoco insieme il valore da liberare e le mosse da fare."
  >
    <Fragment slot="title">Pronti a incontrare<br />i vostri <em>advisor?</em></Fragment>
  </CtaBand>
</BaseLayout>

<style>
  .team-page { padding: 80px 0; }
  .team-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 30px;
  }
  .member {
    background: var(--panel);
    border: 1px solid var(--hair-faint);
    border-radius: var(--radius-card);
    overflow: hidden;
    transition: border-color 0.35s ease, transform 0.35s ease, box-shadow 0.35s ease;
  }
  .member:hover {
    border-color: var(--hair);
    transform: translateY(-5px);
    box-shadow: 0 18px 40px rgba(6, 27, 61, 0.08);
  }
  .member-body { padding: 22px 24px 26px; }
  .member h3 { font-size: 22px; }
  .pos {
    font-family: var(--sans); font-size: 12px; font-weight: 700;
    letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--accent-text); margin-top: 8px;
  }
  .note {
    font-family: var(--sans); font-size: 11px; font-weight: 600;
    letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--muted-2); margin-top: 14px;
    border-top: 1px solid var(--hair-faint); padding-top: 12px;
  }

  @media (max-width: 1024px) {
    .team-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 700px) {
    .team-grid { grid-template-columns: 1fr; }
  }
</style>
